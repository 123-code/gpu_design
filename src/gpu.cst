// ============================================================================
// Tang Nano 20K (GW2AR-LV18QN88C8/I7) physical pin constraints for tiny-gpu.
// Top module: top  (src/top.sv)
//
// Pin numbers verified against the Sipeed Tang Nano 20K schematic / wiki:
//   - 27 MHz crystal -> PIN 4
//   - LED0..LED5     -> PIN 15,16,17,18,19,20  (active-LOW)
//   - UART TX/RX     -> PIN 69 / PIN 70        (onboard USB-serial)
// ============================================================================

// ---- 27 MHz system clock ----
IO_LOC  "clk" 4;
IO_PORT "clk" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// ---- UART -> onboard USB-serial bridge (BL616), 115200 8N1 ----
// FPGA TX is PIN 69, FPGA RX is PIN 70 on the Tang Nano 20K.
IO_LOC  "uart_tx_out" 69;
IO_PORT "uart_tx_out" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
IO_LOC  "uart_rx_in" 70;
IO_PORT "uart_rx_in" IO_TYPE=LVCMOS33 PULL_MODE=UP;

// ---- 6 onboard LEDs (active-low) ----
IO_LOC  "led[0]" 15;
IO_PORT "led[0]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
IO_LOC  "led[1]" 16;
IO_PORT "led[1]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
IO_LOC  "led[2]" 17;
IO_PORT "led[2]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
IO_LOC  "led[3]" 18;
IO_PORT "led[3]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
IO_LOC  "led[4]" 19;
IO_PORT "led[4]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
IO_LOC  "led[5]" 20;
IO_PORT "led[5]" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8;
